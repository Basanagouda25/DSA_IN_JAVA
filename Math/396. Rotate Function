class Solution {
    public int maxRotateFunction(int[] nums) {
        int n = nums.length;
        
        long sum = 0;
        long fun = 0;
        for(int i = 0; i < n; i++){
            sum += nums[i];
            fun += (long) i * nums[i];
        }
        long maxnum = fun;
        for(int i = n -1; i > 0; i--){
            fun = fun + sum - ((long)n * nums[i]);
            maxnum = Math.max(maxnum,fun);
        }
        return (int) maxnum;
    }
}
