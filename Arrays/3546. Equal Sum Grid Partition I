class Solution {
    public boolean canPartitionGrid(int[][] grid) {
        int m = grid.length;
        int n = grid[0].length;
        long[] rowsum = new long[m];
        long[] colsum = new long[n];
        long total = 0;
        for(int i = 0; i < m; i++){
            for(int j = 0; j < n; j++){
                total += grid[i][j];
                rowsum[i] += grid[i][j];
                colsum[j] += grid[i][j];
            }
        }
        if(total % 2 != 0){
            return false;
        }
        long upper = 0;
        for(int i = 0; i < m - 1; i++){
            upper += rowsum[i];
            if(upper == total - upper){
                return true;
            }
        }
        long left = 0;
        for(int j = 0; j < n - 1; j++){
            left += colsum[j];
            if(left == total - left){
                return true;
            }
        }
        return false;
    }
}
