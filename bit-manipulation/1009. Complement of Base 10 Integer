class Solution {
    public int bitwiseComplement(int n) {
        //Base case
        if(n == 0){
            return 1;
        }

        // make a string and convert decimal to binary
        String res = "";
        while(n > 0){
            res = (n % 2) + res;
            n /= 2;
        }

        //take a complement of that string
        StringBuilder comp = new StringBuilder();
        for(int i=0; i<res.length(); i++){
            if(res.charAt(i) == '0'){
                comp.append('1');
            }else{
                comp.append('0');
            }
        }

        //iterate through a complemented string convert it to decimal
        String compstr = comp.toString();
        int sum = 0;
        int power = 1;
        int len = compstr.length();
        for(int i=len-1; i>=0; i--){
            if(compstr.charAt(i) == '1'){
                sum += power;
            }
            power *= 2;
        }
        return sum;
    }
}
